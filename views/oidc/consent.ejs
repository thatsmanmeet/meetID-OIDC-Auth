<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: title }) %>
<body class="consent-page">
  <div class="consent-card">
    <%- include('../partials/flash') %>

    <div class="consent-issuer">🔐 MeetID</div>

    <div class="consent-header">
      <div class="consent-app-icon">⚙️</div>
      <h2><%= application.name %> wants access</h2>
      <p>Review the permissions this application is requesting before granting access.</p>
    </div>

    <!-- Signed-in user -->
    <div class="consent-user-strip">
      <div class="mini-avatar">
        <% if (profile && profile.avatar) { %>
          <img src="<%= profile.avatar %>" alt="avatar" />
        <% } else { %>
          <%= (profile && profile.firstName ? profile.firstName : 'U').charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="mini-info">
        Signing in as&nbsp;<strong><%= profile ? profile.firstName + (profile.lastName ? ' ' + profile.lastName : '') : 'You' %></strong>
        <% if (profile && profile.email) { %><br/><span><%= profile.email %></span><% } %>
      </div>
    </div>

    <!-- Permissions -->
    <div class="consent-perms">
      <h3>Permissions requested</h3>
      <div class="consent-perm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Read your profile (name, email)
      </div>
      <div class="consent-perm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Verify your identity via MeetID
      </div>
    </div>

    <% if (application.privacyPolicyURL) { %>
    <p style="font-size:12.5px;color:#64748b;margin-bottom:18px;text-align:center">
      By approving, you agree to <a href="<%= application.privacyPolicyURL %>" target="_blank" rel="noopener"><%= application.name %>'s Privacy Policy</a>.
    </p>
    <% } %>

    <form action="/oidc/authorize" method="POST">
      <input type="hidden" name="client_id" value="<%= client_id %>" />
      <input type="hidden" name="redirect_uri" value="<%= redirect_uri %>" />
      <input type="hidden" name="state" value="<%= state || '' %>" />
      <div class="consent-actions">
        <button type="submit" name="action" value="deny" class="btn btn-secondary">
          Deny
        </button>
        <button type="submit" name="action" value="approve" class="btn btn-primary">
          Approve Access
        </button>
      </div>
    </form>

    <p class="consent-foot">
      Authorizing will redirect you to <strong><%= redirect_uri.length > 50 ? redirect_uri.substring(0, 50) + '…' : redirect_uri %></strong>
    </p>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
