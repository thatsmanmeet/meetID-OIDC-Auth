<aside class="sidebar">
  <div class="sidebar-logo">
    <h1>Meet<span>ID</span></h1>
    <small>Identity Provider</small>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">Developer</div>
    <a href="/dashboard">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
      Applications
    </a>
    <div class="nav-section">Account</div>
    <a href="/profile">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Profile
    </a>
    <a href="/profile/consented-apps">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Connected Apps
    </a>
    <hr class="sidebar-divider" />
    <form action="/logout" method="POST" style="margin:0">
      <button type="submit" class="sidebar-signout-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign Out
      </button>
    </form>
  </nav>
  <% if (typeof user !== 'undefined' && user) { %>
  <div class="sidebar-user">
    <div class="sidebar-avatar">
      <% if (typeof profile !== 'undefined' && profile && profile.avatar) { %>
        <img src="<%= profile.avatar %>" alt="avatar" />
      <% } else { %>
        <%= (user.firstName || 'U').charAt(0).toUpperCase() %>
      <% } %>
    </div>
    <div class="sidebar-user-info">
      <div class="sidebar-user-name"><%= user.firstName || 'User' %></div>
      <div class="sidebar-user-email"><%= user.email || '' %></div>
    </div>
  </div>
  <% } %>
</aside>
