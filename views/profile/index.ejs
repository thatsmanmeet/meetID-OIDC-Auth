<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: title }) %>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <div class="page-header-text">
        <h1>Profile</h1>
        <p>Manage your personal information and password</p>
      </div>
    </div>

    <!-- Profile Info -->
    <div class="card" style="max-width:600px">
      <div class="card-header">
        <h2>Personal Information</h2>
      </div>
      <div class="card-body">
        <form action="/profile/update" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="firstName">First Name</label>
              <input type="text" id="firstName" name="firstName" class="form-input"
                value="<%= profile.firstName %>" maxlength="50" />
            </div>
            <div class="form-group">
              <label class="form-label" for="lastName">Last Name <span>(optional)</span></label>
              <input type="text" id="lastName" name="lastName" class="form-input"
                value="<%= profile.lastName || '' %>" maxlength="50" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" class="form-input" value="<%= profile.email %>" disabled style="opacity:0.6;cursor:not-allowed" />
            <p class="form-hint">Email cannot be changed.</p>
          </div>
          <button type="submit" class="btn btn-primary">Update Profile</button>
        </form>
      </div>
    </div>

    <!-- Change Password -->
    <div class="card" style="max-width:600px;margin-top:20px">
      <div class="card-header">
        <h2>Change Password</h2>
      </div>
      <div class="card-body">
        <form action="/profile/update" method="POST">
          <div class="form-group">
            <label class="form-label" for="oldPassword">Current Password</label>
            <input type="password" id="oldPassword" name="oldPassword" class="form-input"
              placeholder="••••••••" autocomplete="current-password" />
          </div>
          <div class="form-group">
            <label class="form-label" for="password">New Password</label>
            <input type="password" id="password" name="password" class="form-input"
              placeholder="Min. 8 characters" autocomplete="new-password" />
          </div>
          <div class="form-group">
            <label class="form-label" for="confirmPassword">Confirm New Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" class="form-input"
              placeholder="Repeat new password" autocomplete="new-password" />
          </div>
          <button type="submit" class="btn btn-primary">Change Password</button>
        </form>
      </div>
    </div>

    <!-- Avatar -->
    <div class="card" style="max-width:600px;margin-top:20px">
      <div class="card-header">
        <div>
          <h2>Avatar</h2>
          <p>A URL to your profile picture.</p>
        </div>
      </div>
      <div class="card-body">
        <% if (profile.avatar) { %>
        <div style="margin-bottom:16px">
          <img src="<%= profile.avatar %>" alt="Avatar" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid #e2e8f0" />
        </div>
        <% } %>
        <form action="/profile/avatar" method="POST">
          <div class="form-group">
            <label class="form-label" for="avatar">Avatar URL</label>
            <input type="url" id="avatar" name="avatar" class="form-input"
              value="<%= profile.avatar || '' %>" placeholder="https://example.com/avatar.png" />
          </div>
          <button type="submit" class="btn btn-primary">Update Avatar</button>
        </form>
      </div>
    </div>

    <!-- Account Info -->
    <div class="card" style="max-width:600px;margin-top:20px">
      <div class="card-header"><h2>Account Info</h2></div>
      <div class="card-body">
        <div class="info-row">
          <span class="info-label">Account ID</span>
          <span class="info-value mono text-sm"><%= profile.id %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Email Verified</span>
          <span class="info-value">
            <% if (profile.emailVerified) { %>
              <span class="badge badge-success">Verified</span>
            <% } else { %>
              <span class="badge badge-warning">Not Verified</span>
            <% } %>
          </span>
        </div>
        <div class="info-row">
          <span class="info-label">Member Since</span>
          <span class="info-value text-sm"><%= new Date(profile.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
      </div>
    </div>

  </main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
